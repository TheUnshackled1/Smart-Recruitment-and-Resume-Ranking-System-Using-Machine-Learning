# Copy this file to .env and fill in real values. The .env file is gitignored
# and must NOT be committed. settings.py auto-loads it on startup.

# Gmail SMTP
EMAIL_HOST_USER=your.address@gmail.com
EMAIL_HOST_PASSWORD=PASTE_16_CHAR_APP_PASSWORD_NO_SPACES

# Optional: where the contact form delivers (defaults to EMAIL_HOST_USER)
# CONTACT_EMAIL=admin@example.com
